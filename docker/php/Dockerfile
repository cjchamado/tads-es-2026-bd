FROM php:8.4-fpm

LABEL maintainer="Claudinei José Machado"

###############################################################################
# Variáveis
###############################################################################

ARG UID=1000
ARG GID=1000

###############################################################################
# Dependências do Sistema
###############################################################################

RUN apt-get update && apt-get install -y \
    git \
    curl \
    unzip \
    zip \
    nano \
    procps \
    libicu-dev \
    libzip-dev \
    libpng-dev \
    libjpeg62-turbo-dev \
    libfreetype6-dev \
    libonig-dev \
    libxml2-dev \
    libpq-dev \
    libsqlite3-dev \
    libsqlite3-0 \
    && rm -rf /var/lib/apt/lists/*

###############################################################################
# Configuração da GD
###############################################################################

RUN docker-php-ext-configure gd \
    --with-freetype \
    --with-jpeg

###############################################################################
# Extensões PHP
###############################################################################

RUN docker-php-ext-install -j$(nproc) \
    bcmath \
    exif \
    gd \
    intl \
    mysqli \
    opcache \
    pcntl \
    pdo_mysql \
    pdo_sqlite \
    zip

###############################################################################
# Redis
###############################################################################

RUN pecl install redis \
    && docker-php-ext-enable redis

###############################################################################
# Composer
###############################################################################

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

###############################################################################
# Usuário da Aplicação
###############################################################################

RUN groupmod -g ${GID} www-data && \
    usermod -u ${UID} -g ${GID} www-data

###############################################################################
# Diretório de Trabalho
###############################################################################

WORKDIR /var/www

###############################################################################
# Permissões
###############################################################################

RUN chown -R www-data:www-data /var/www

###############################################################################
# Usuário Padrão
###############################################################################

USER www-data

###############################################################################
# Porta do PHP-FPM
###############################################################################

EXPOSE 9000

CMD ["php-fpm"]
